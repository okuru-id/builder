APP_NAME=Goravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_URL=http://localhost
APP_HOST=127.0.0.1
APP_PORT=3000

JWT_SECRET=

# 2FA/OTP. Omit to auto-disable for local/dev/testing envs.
TOTP_ENABLED=

DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=okuruid
DB_USERNAME=postgres
DB_PASSWORD=password

# LLM / AI Agent (builder.okuru.id AI chat). OpenAI-compatible API.
# LLM only used when LLM_API_KEY is set.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

GRPC_HOST=
GRPC_PORT=

MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
